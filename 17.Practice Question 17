#include <stdio.h>

int main() {
    FILE *fp;
    char name[100];

    fp = fopen("student.txt", "w");

    if (fp == NULL) {
        printf("Error opening file.\n");
        return 1;
    }

    printf("Enter student's name: ");
    fgets(name, sizeof(name), stdin);

    fprintf(fp, "%s", name);

    printf("Student name written to student.txt successfully.\n");

    fclose(fp);

    return 0;
}
