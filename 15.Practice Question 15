#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/wait.h>

int main() {
    int i;
    pid_t pid;

    for (i = 0; i < 3; i++) {
        pid = fork();

        if (pid < 0) {
            printf("Fork failed!\n");
            return 1;
        }
        else if (pid == 0) {
            printf("Child %d\n", i + 1);
            printf("PID  : %d\n", getpid());
            printf("PPID : %d\n\n", getppid());
            exit(0);   // Child terminates
        }
    }
    for (i = 0; i < 3; i++) {
        wait(NULL);
    }

    printf("Parent Process\n");
    printf("PID : %d\n", getpid());

    return 0;
}
