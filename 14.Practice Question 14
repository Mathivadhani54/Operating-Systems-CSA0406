#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/wait.h>

int main() {
    pid_t pid;
    pid = fork();

    if (pid < 0) {
        printf("Fork failed!\n");
        return 1;
    }
    else if (pid == 0) {
        printf("Child Process Started.\n");
        printf("Child PID: %d\n", getpid());

        sleep(2);  

        printf("Child Process Completed.\n");
        exit(0);
    }
    else {
   
        printf("Parent is waiting for the child to complete...\n");
        wait(NULL);

        printf("Parent Process Resumed.\n");
    }

    return 0;
}
