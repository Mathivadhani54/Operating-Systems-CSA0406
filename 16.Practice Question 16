#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/stat.h>

int main() {
    int fd;
    fd = open("student.txt", O_CREAT | O_WRONLY, 0644);

    if (fd < 0) {
        printf("Error creating file.\n");
        return 1;
    }
    printf("File 'student.txt' created successfully.\n");
    close(fd);

    return 0;
}
